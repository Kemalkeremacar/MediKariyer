{
  "development": {
    "server": "localhost",
    "database": "medikariyer_docs_dev",
    "user": "sa",
    "password": "",
    "options": {
      "encrypt": false,
      "trustServerCertificate": true,
      "enableArithAbort": true
    },
    "pool": {
      "max": 10,
      "min": 0,
      "idleTimeoutMillis": 30000
    }
  },
  "test": {
    "server": "localhost",
    "database": "medikariyer_docs_test",
    "user": "sa",
    "password": "",
    "options": {
      "encrypt": false,
      "trustServerCertificate": true,
      "enableArithAbort": true
    },
    "pool": {
      "max": 5,
      "min": 0,
      "idleTimeoutMillis": 30000
    }
  },
  "production": {
    "server": "${DB_SERVER}",
    "database": "${DB_NAME}",
    "user": "${DB_USER}",
    "password": "${DB_PASSWORD}",
    "options": {
      "encrypt": true,
      "trustServerCertificate": false,
      "enableArithAbort": true
    },
    "pool": {
      "max": 20,
      "min": 5,
      "idleTimeoutMillis": 30000
    }
  }
}